{
  "name": "nodejs-jenkins-k8s-cicd-lab",
  "version": "1.0.0",
  "description": "Order Status API for CI/CD labs with Jenkins, Docker Hub, and Kubernetes.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "verify": "npm run lint && npm test",
    "jenkins:job:dry-run": "node scripts/jenkins/create-pipeline-job.mjs",
    "jenkins:job:apply": "node scripts/jenkins/create-pipeline-job.mjs --apply",
    "jenkins:job:apply-build": "node scripts/jenkins/create-pipeline-job.mjs --apply --build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
